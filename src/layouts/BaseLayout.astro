---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';

const { title = "Iuris Consultus | Abogados y Notarios", description = "Firma de Abogados y Notarios — Iuris Consultus. Asesoría jurídica integral con los más altos estándares de profesionalismo." } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://iurisnicaragua.com');
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content="https://iurisnicaragua.com/logo.webp" />
    <meta property="og:locale" content="es_NI" />
    <meta property="og:site_name" content="Iuris Consultus" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fuentes: Playfair Display + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">

    <title>{title}</title>

    <link rel="icon" type="image/webp" href="/favicon.webp" />

    <!-- Vercel Analytics -->
    <Analytics />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LegalService",
      "name": "Iuris Consultus",
      "description": "Firma de Abogados y Notarios en Nicaragua. Asesoría jurídica integral.",
      "url": "https://iurisnicaragua.com",
      "logo": "https://iurisnicaragua.com/logo.webp",
      "telephone": "+50522324191",
      "email": "info@iurisnicaragua.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Edificio Plaza Centroamérica, 7mo. piso, suite 703",
        "addressLocality": "Managua",
        "addressCountry": "NI"
      },
      "areaServed": "Nicaragua",
      "priceRange": "$$"
    })} />
  </head>
  <body class="bg-brand-light text-brand-dark antialiased flex flex-col min-h-screen">
    
    <Header />

    <main class="grow flex flex-col">
      <slot />
    </main>

    <Footer />
    
    <SpeedInsights />
    <Analytics />

    <!-- Scroll Reveal Observer (works on mobile/tablet/desktop) -->
    <script>
      function initRevealObserver() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.05, rootMargin: '0px 0px -20px 0px' });

        document.querySelectorAll('.scroll-reveal, .scroll-reveal-left, .scroll-reveal-right').forEach((el) => {
          observer.observe(el);
        });
      }

      // Ensure DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRevealObserver);
      } else {
        initRevealObserver();
      }
    </script>
  </body>
</html>