---
import { Facebook, Linkedin, Instagram } from 'lucide-react';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent">
  <!-- Gold accent bar -->
  <div class="h-0.5 gold-gradient"></div>

  <!-- Top Bar (Socials) -->
  <div class="hidden lg:block border-b border-white/10">
    <div class="container mx-auto px-6 py-2 flex justify-end items-center gap-5">
      <a href="#" aria-label="Facebook" class="text-white/80 hover:text-brand-accent transition-colors cursor-pointer">
        <Facebook size={16} />
      </a>
      <a href="#" aria-label="LinkedIn" class="text-white/80 hover:text-brand-accent transition-colors cursor-pointer">
        <Linkedin size={16} />
      </a>
      <a href="https://www.instagram.com/iuris_nicaragua/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-white/80 hover:text-brand-accent transition-colors cursor-pointer">
        <Instagram size={16} />
      </a>
      <a href="https://wa.me/50522324191" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="text-white/80 hover:text-[#25D366] transition-colors cursor-pointer group relative">
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-[16px] h-[16px]"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span class="absolute top-full mt-2 right-0 bg-white text-gray-800 text-xs font-serif px-2 py-1 rounded shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap pointer-events-none">¿Necesita ayuda legal?</span>
      </a>
    </div>
  </div>
  
  <div class="container mx-auto px-6 py-4 flex items-center justify-between lg:grid lg:grid-cols-3">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group cursor-pointer relative z-50 lg:justify-self-start">
      <img src="/logo.webp" alt="Iuris Consultus" class="h-10 md:h-12 w-auto transition-transform duration-300 group-hover:scale-105" width="48" height="48" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex justify-center items-center gap-1 lg:justify-self-center">
      <a href="/" class="nav-link px-4 py-2 font-serif text-[15px] font-semibold tracking-wide uppercase text-white hover:text-brand-accent transition-colors duration-300 relative cursor-pointer nav-text-contrast">
        Inicio
        <span class="nav-underline absolute bottom-0 left-4 right-4 h-0.5 bg-brand-accent scale-x-0 transition-transform duration-300 origin-left"></span>
      </a>
      <a href="/nosotros" class="nav-link px-4 py-2 font-serif text-[15px] font-semibold tracking-wide uppercase text-white hover:text-brand-accent transition-colors duration-300 relative cursor-pointer nav-text-contrast">
        Nosotros
        <span class="nav-underline absolute bottom-0 left-4 right-4 h-0.5 bg-brand-accent scale-x-0 transition-transform duration-300 origin-left"></span>
      </a>
      <a href="/servicios" class="nav-link px-4 py-2 font-serif text-[15px] font-semibold tracking-wide uppercase text-white hover:text-brand-accent transition-colors duration-300 relative cursor-pointer nav-text-contrast">
        Servicios
        <span class="nav-underline absolute bottom-0 left-4 right-4 h-0.5 bg-brand-accent scale-x-0 transition-transform duration-300 origin-left"></span>
      </a>
      <a href="/blog" class="nav-link px-4 py-2 font-serif text-[15px] font-semibold tracking-wide uppercase text-white hover:text-brand-accent transition-colors duration-300 relative cursor-pointer nav-text-contrast">
        Blog
        <span class="nav-underline absolute bottom-0 left-4 right-4 h-0.5 bg-brand-accent scale-x-0 transition-transform duration-300 origin-left"></span>
      </a>
    </nav>

    <!-- Right Actions -->
    <div class="flex items-center gap-4 lg:justify-self-end">
      <a href="/contacto" class="hidden lg:inline-block px-6 py-2.5 bg-brand-accent text-white font-serif text-[15px] font-bold uppercase tracking-wider hover:bg-brand-accent-light transition-all duration-300 rounded-sm shadow-md hover:shadow-lg cursor-pointer">
        Contacto
      </a>
      
      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden text-white focus:outline-none cursor-pointer p-2 relative z-50" aria-label="Abrir menú">
        <div id="hamburger-lines" class="w-6 h-5 flex flex-col justify-between relative">
          <span class="hamburger-line w-full h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
          <span class="hamburger-line w-full h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
          <span class="hamburger-line w-4 h-0.5 bg-white rounded-full transition-all duration-300 origin-center ml-auto"></span>
        </div>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[60] lg:hidden" style="opacity: 0; pointer-events: none; transition: opacity 0.3s;"></div>

<!-- Mobile Menu Panel -->
<div id="mobile-menu" class="fixed top-0 right-0 h-full w-[85%] max-w-sm bg-brand-primary z-[60] lg:hidden shadow-2xl" style="transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);">
  <div class="flex flex-col h-full">
    <!-- Menu Header -->
    <div class="px-8 pt-8 pb-6 border-b border-white/10 flex justify-between items-start">
      <div>
        <img src="/logo.webp" alt="Iuris Consultus" class="h-10 w-auto" width="40" height="40" />
        <p class="text-white/50 text-xs mt-3 tracking-wider uppercase">Abogados y Notarios</p>
      </div>
      <button id="mobile-menu-close" class="text-white/50 hover:text-white transition-colors cursor-pointer p-1 -mr-1" aria-label="Cerrar menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>

    <!-- Menu Links -->
    <nav class="flex flex-col px-8 py-8 gap-1 grow overflow-y-auto">
      <a href="/" class="mobile-nav-link menu-content-stagger text-white/80 hover:text-brand-accent hover:bg-white/[0.03] active:bg-white/[0.06] active:scale-[0.98] transition-all duration-300 py-3.5 px-4 -mx-4 rounded-lg text-base font-serif font-medium tracking-wide uppercase border-b border-transparent hover:border-white/5 cursor-pointer flex items-center justify-between group">
        Inicio
        <svg class="w-4 h-4 text-brand-accent/50 group-hover:text-brand-accent group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>
      <a href="/nosotros" class="mobile-nav-link menu-content-stagger text-white/80 hover:text-brand-accent hover:bg-white/[0.03] active:bg-white/[0.06] active:scale-[0.98] transition-all duration-300 py-3.5 px-4 -mx-4 rounded-lg text-base font-serif font-medium tracking-wide uppercase border-b border-transparent hover:border-white/5 cursor-pointer flex items-center justify-between group">
        Nosotros
        <svg class="w-4 h-4 text-brand-accent/50 group-hover:text-brand-accent group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>
      <a href="/servicios" class="mobile-nav-link menu-content-stagger text-white/80 hover:text-brand-accent hover:bg-white/[0.03] active:bg-white/[0.06] active:scale-[0.98] transition-all duration-300 py-3.5 px-4 -mx-4 rounded-lg text-base font-serif font-medium tracking-wide uppercase border-b border-transparent hover:border-white/5 cursor-pointer flex items-center justify-between group">
        Servicios
        <svg class="w-4 h-4 text-brand-accent/50 group-hover:text-brand-accent group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>
      <a href="/blog" class="mobile-nav-link menu-content-stagger text-white/80 hover:text-brand-accent hover:bg-white/[0.03] active:bg-white/[0.06] active:scale-[0.98] transition-all duration-300 py-3.5 px-4 -mx-4 rounded-lg text-base font-serif font-medium tracking-wide uppercase border-b border-transparent hover:border-white/5 cursor-pointer flex items-center justify-between group">
        Blog
        <svg class="w-4 h-4 text-brand-accent/50 group-hover:text-brand-accent group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>
      <a href="/contacto" class="mt-6 flex-shrink-0 menu-content-stagger text-center px-6 py-3.5 bg-brand-accent text-white font-serif font-bold uppercase tracking-wider rounded-lg active:scale-[0.96] hover:bg-brand-accent-light transition-all duration-300 cursor-pointer shadow-[0_4px_14px_rgba(184,150,12,0.3)] hover:shadow-[0_6px_20px_rgba(184,150,12,0.4)] text-sm">
        Contacto
      </a>
    </nav>

    <!-- Menu Footer -->
    <div class="px-8 py-6 border-t border-white/10 mt-auto flex-shrink-0 menu-footer-stagger">
      <a href="tel:+50522324191" class="text-white/50 text-xs hover:text-brand-accent transition-colors flex items-center gap-2 mb-2 cursor-pointer">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
        (505) 2232 4191
      </a>
      <a href="mailto:info@iurisnicaragua.com" class="text-white/50 text-xs hover:text-brand-accent transition-colors flex items-center gap-2 cursor-pointer">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        info@iurisnicaragua.com
      </a>
    </div>
  </div>
</div>

<!-- Spacer -->
<div class="h-18.5"></div>

<style>
  .nav-link:hover .nav-underline,
  .nav-link.active .nav-underline {
    transform: scaleX(1);
  }
  .nav-link.active {
    color: var(--color-brand-accent);
  }
  /* text-shadow for nav links over light sections */
  .nav-text-contrast {
    text-shadow: 0 1px 8px rgba(0,0,0,0.55), 0 0 24px rgba(0,0,0,0.25);
  }
  #site-header.scrolled .nav-text-contrast {
    text-shadow: none;
  }
  #site-header.scrolled {
    background-color: rgba(10, 13, 35, 0.98);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    box-shadow: 0 2px 30px rgba(0, 0, 0, 0.28), 0 1px 0 rgba(184,150,12,0.18);
  }
  
  /* Hide header on scroll down */
  #site-header.hide-header {
    transform: translateY(-100%);
  }
  
  /* Hamburger Animation */
  .menu-open .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-open .hamburger-line:nth-child(3) {
    width: 100%;
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Mobile menu slide transition */
  #mobile-menu {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1); /* Smoother bounce-like curve */
  }
  #mobile-menu.open {
    transform: translateX(0) !important;
  }
  #mobile-menu-overlay.open {
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  /* Staggered content animations inside mobile menu */
  #mobile-menu .menu-content-stagger {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.4s ease, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  
  #mobile-menu.open .menu-content-stagger {
    opacity: 1;
    transform: translateY(0);
  }

  /* Delay for each element */
  #mobile-menu.open .menu-content-stagger:nth-child(1) { transition-delay: 0.10s; }
  #mobile-menu.open .menu-content-stagger:nth-child(2) { transition-delay: 0.15s; }
  #mobile-menu.open .menu-content-stagger:nth-child(3) { transition-delay: 0.20s; }
  #mobile-menu.open .menu-content-stagger:nth-child(4) { transition-delay: 0.25s; }
  #mobile-menu.open .menu-content-stagger:nth-child(5) { transition-delay: 0.30s; }
  
  /* Footer fade */
  #mobile-menu .menu-footer-stagger {
    opacity: 0;
    transition: opacity 0.5s ease 0.4s;
  }
  #mobile-menu.open .menu-footer-stagger {
    opacity: 1;
  }

  /* Rotating close button on open */
  #mobile-menu-close svg {
    transform: rotate(-90deg);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.1s;
  }
  #mobile-menu.open #mobile-menu-close svg {
    transform: rotate(0deg);
  }
</style>

<script>
// Scroll effect
  let lastScrollY = window.scrollY;
  const header = document.getElementById('site-header');

  function handleScroll() {
    if (!header) return;

    // Background transition
    if (window.scrollY > 60) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }

    // Hide on scroll down, show on scroll up
    if (window.scrollY > lastScrollY && window.scrollY > 200) {
      header.classList.add('hide-header');
    } else {
      header.classList.remove('hide-header');
    }
    
    lastScrollY = window.scrollY;
  }
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Active page indicator
  const currentPath = window.location.pathname;
  document.querySelectorAll('.nav-link').forEach(link => {
    const href = link.getAttribute('href');
    if (href === currentPath || (href === '/' && currentPath === '/')) {
      link.classList.add('active');
    }
  });

  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const hamburger = document.getElementById('hamburger-lines');

  function toggleMenu() {
    const isOpen = menu?.classList.contains('open');
    if (isOpen) {
      menu?.classList.remove('open');
      overlay?.classList.remove('open');
      hamburger?.classList.remove('menu-open');
      document.body.style.overflow = '';
    } else {
      menu?.classList.add('open');
      overlay?.classList.add('open');
      hamburger?.classList.add('menu-open');
      document.body.style.overflow = 'hidden';
    }
  }

  btn?.addEventListener('click', toggleMenu);
  closeBtn?.addEventListener('click', toggleMenu);
  overlay?.addEventListener('click', toggleMenu);

  // Close on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.remove('open');
      overlay?.classList.remove('open');
      hamburger?.classList.remove('menu-open');
      document.body.style.overflow = '';
    });
  });
</script>
