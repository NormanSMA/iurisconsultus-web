---


interface Props {
  
  href?: string;
  variant?: 'gold' | 'outline' | 'ghost' | 'dark';
  size?: 'md' | 'lg';
  class?: string;
  target?: string;
  rel?: string;
  type?: 'button' | 'submit' | 'reset';
  
  group?: boolean;
}

const {
  href,
  variant = 'gold',
  size = 'md',
  class: className = '',
  target,
  rel,
  type = 'button',
  group = false,
} = Astro.props;

const classes = [
  'btn',
  `btn-${variant}`,
  `btn-${size}`,
  group ? 'group' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

{href ? (
  <a href={href} class={classes} target={target} rel={rel}>
    <slot />
    <span class="ripple-circle"></span>
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
    <span class="ripple-circle"></span>
  </button>
)}

