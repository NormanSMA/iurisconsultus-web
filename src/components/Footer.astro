---
import { MapPin, Phone, Mail, Facebook, Linkedin, Instagram } from 'lucide-react';
---

<footer class="bg-brand-dark text-gray-300 relative overflow-hidden">
  <!-- Gold top border -->
  <div class="h-1 gold-gradient"></div>
  
  <div class="container mx-auto px-6 pt-16 pb-10 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-6 cursor-pointer group">
          <!-- Logo on dark background: use invert filter to make it white/light -->
          <img
            src="/logo.webp"
            alt="Iuris Consultus"
            class="h-16 w-auto footer-logo transition-transform duration-300 group-hover:scale-105"
            width="64" height="64"
          />
        </a>
        <p class="text-sm leading-relaxed text-gray-400 mb-6 max-w-xs">
          Firma de abogados y notarios dedicada a soluciones jurídicas integrales con los más altos estándares de profesionalismo y ética desde 1991.
        </p>
        <div class="flex gap-3">
          <a href="#" aria-label="Facebook" class="w-10 h-10 flex items-center justify-center bg-white/5 text-gray-400 rounded-sm hover:bg-brand-accent hover:text-white transition-all duration-300 cursor-pointer">
            <Facebook size={18} />
          </a>
          <a href="#" aria-label="LinkedIn" class="w-10 h-10 flex items-center justify-center bg-white/5 text-gray-400 rounded-sm hover:bg-brand-accent hover:text-white transition-all duration-300 cursor-pointer">
            <Linkedin size={18} />
          </a>
          <a href="https://www.instagram.com/iuris_nicaragua/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 flex items-center justify-center bg-white/5 text-gray-400 rounded-sm hover:bg-brand-accent hover:text-white transition-all duration-300 cursor-pointer">
            <Instagram size={18} />
          </a>
          <a href="https://wa.me/50522324191" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-10 h-10 flex items-center justify-center bg-white/5 text-gray-400 rounded-sm hover:bg-[#25D366] hover:text-white transition-all duration-300 cursor-pointer group relative">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-[18px] h-[18px]"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span class="absolute bottom-full mb-3 left-1/2 -translate-x-1/2 bg-white text-gray-800 text-xs font-semibold px-3 py-2 rounded-md shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap pointer-events-none">
              ¿Necesita ayuda legal?
            </span>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white text-sm font-bold mb-6 uppercase tracking-[0.2em] relative pb-3">
          Navegación
          <span class="absolute bottom-0 left-0 w-8 h-0.5 bg-brand-accent"></span>
        </h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li><a href="/" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Inicio</a></li>
          <li><a href="/nosotros" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Nuestro Equipo</a></li>
          <li><a href="/servicios" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Áreas de Práctica</a></li>
          <li><a href="/blog" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Centro de Noticias</a></li>
          <li><a href="/contacto" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Contacto</a></li>
        </ul>
      </div>

      <!-- Practice Areas -->
      <div>
        <h3 class="text-white text-sm font-bold mb-6 uppercase tracking-[0.2em] relative pb-3">
          Áreas de Práctica
          <span class="absolute bottom-0 left-0 w-8 h-0.5 bg-brand-accent"></span>
        </h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li><a href="/servicios" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Bancario y Financiero</a></li>
          <li><a href="/servicios" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Servicios Notariales</a></li>
          <li><a href="/servicios" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Litigios Civiles</a></li>
          <li><a href="/servicios" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Derecho Laboral</a></li>
          <li><a href="/servicios" class="text-gray-400 hover:text-brand-accent hover:translate-x-1 transition-all duration-200 inline-block cursor-pointer">Administrativo y Fiscal</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white text-sm font-bold mb-6 uppercase tracking-[0.2em] relative pb-3">
          Contacto
          <span class="absolute bottom-0 left-0 w-8 h-0.5 bg-brand-accent"></span>
        </h3>
        <ul class="flex flex-col gap-4 text-sm">
          <li class="flex items-start gap-3">
            <MapPin className="text-brand-accent shrink-0 mt-0.5" size={16} />
            <a href="https://maps.app.goo.gl/8KSVohwukoRgZsr67" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-brand-accent transition-colors cursor-pointer">Edificio Plaza Centroamérica,<br/>7mo. piso, suite 703.<br/>Managua, Nicaragua.</a>
          </li>
          <li class="flex items-center gap-3">
            <Phone className="text-brand-accent shrink-0" size={16} />
            <a href="tel:+50522324191" class="text-gray-400 hover:text-brand-accent transition-colors cursor-pointer">(505) 2232 4191</a>
          </li>
          <li class="flex items-center gap-3">
            <Mail className="text-brand-accent shrink-0" size={16} />
            <a href="mailto:info@iurisnicaragua.com" class="text-gray-400 hover:text-brand-accent transition-colors cursor-pointer">info@iurisnicaragua.com</a>
          </li>
        </ul>


      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/5">
    <div class="container mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-500">&copy; {new Date().getFullYear()} Iuris Consultus — Abogados y Notarios. Todos los derechos reservados.</p>
      <p class="text-xs text-gray-600">Managua, Nicaragua</p>
    </div>
  </div>
</footer>

<style>
  /* Footer logo on dark background:
     Boost brightness + add subtle drop-shadow to ensure visibility.
     We avoid brightness(0) invert(1) because it makes the logo a solid white square. */
  .footer-logo {
    filter: brightness(10) drop-shadow(0 0 2px rgba(255,255,255,0.1));
    opacity: 0.90;
  }
  .footer-logo:hover {
    filter: brightness(10) drop-shadow(0 0 8px rgba(184,150,12,0.5));
    opacity: 1;
  }
</style>
