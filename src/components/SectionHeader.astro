---
/**
 * SectionHeader — Header estandarizado para todas las secciones
 *
 * Genera: eyebrow pill + título H2 + divisor dorado + descripción opcional.
 * Elimina el copy-paste de los 4-6 elementos repetidos en cada sección.
 *
 * Uso:
 *   <SectionHeader
 *     eyebrow="La Firma"
 *     title="¿Por qué Iuris Consultus?"
 *     description="Nuestro enfoque combina vasta experiencia..."
 *   />
 *
 *   <!-- Alineado a la izquierda (sin mx-auto en el wrapper) -->
 *   <SectionHeader
 *     align="left"
 *     eyebrow="Especialidades"
 *     title="Soluciones Legales a Su Medida"
 *   />
 */

interface Props {
  /** Texto del eyebrow (línea pequeña sobre el título) */
  eyebrow?: string;
  /** Título principal H2 */
  title: string;
  /** Párrafo descriptivo debajo del divisor */
  description?: string;
  /** Alineación: centrado (default) o izquierda */
  align?: 'center' | 'left';
  /** Clases adicionales en el wrapper */
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  align = 'center',
  class: className = '',
} = Astro.props;

const isCenter = align === 'center';
---

<div class:list={[
  'scroll-reveal',
  { 'text-center max-w-3xl mx-auto': isCenter },
  { 'max-w-none': !isCenter },
  className,
]}>

  {eyebrow && (
    <p class:list={['section-eyebrow', { 'justify-center': isCenter }]}>
      <span class="eyebrow-line"></span>
      {eyebrow}
      {isCenter && <span class="eyebrow-line"></span>}
    </p>
  )}

  <h2 class="text-3xl md:text-5xl font-bold font-serif text-brand-primary mb-4">
    {title}
  </h2>

  <div class:list={[
    'section-divider',
    { 'mt-4 mb-6': isCenter },
    { 'ml-0 mt-0 mb-7 mx-0': !isCenter },
  ]}></div>

  {description && (
    <p class="text-brand-muted text-base leading-relaxed">
      {description}
    </p>
  )}

</div>
