---


interface Props {
  
  eyebrow?: string;
  
  title: string;
  
  description?: string;
  
  align?: 'center' | 'left';
  
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  align = 'center',
  class: className = '',
} = Astro.props;

const isCenter = align === 'center';
---

<div class:list={[
  'scroll-reveal',
  { 'text-center max-w-3xl mx-auto': isCenter },
  { 'max-w-none': !isCenter },
  className,
]}>

  {eyebrow && (
    <p class:list={['section-eyebrow', { 'justify-center': isCenter }]}>
      <span class="eyebrow-line"></span>
      {eyebrow}
      {isCenter && <span class="eyebrow-line"></span>}
    </p>
  )}

  <h2 class="text-3xl md:text-5xl font-bold font-serif text-brand-primary mb-4">
    {title}
  </h2>

  <div class:list={[
    'section-divider',
    { 'mt-4 mb-6': isCenter },
    { 'ml-0 mt-0 mb-7 mx-0': !isCenter },
  ]}></div>

  {description && (
    <p class="text-brand-muted text-base leading-relaxed">
      {description}
    </p>
  )}

</div>

