---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Landmark, ScrollText, Briefcase, Users, Building, ShieldCheck, ArrowRight, CheckCircle2 } from 'lucide-react';

const areas = [
  {
    icon: 'Landmark',
    titulo: 'Bancario y Financiero',
    descripcion: 'Constitución de entidades bancarias, financieras y microfinancieras. Relación con Superintendencia de Bancos (SIBOIF), recuperación de cartera, fideicomisos y dinero electrónico.',
    detalles: [
      'Constitución y regulación de entidades financieras',
      'Relación con SIBOIF y organismos reguladores',
      'Fideicomisos y operaciones de dinero electrónico',
      'Recuperación de cartera y garantías bancarias'
    ]
  },
  {
    icon: 'ScrollText',
    titulo: 'Servicios Notariales',
    descripcion: 'Compraventas, mandatos, constitución de fideicomisos, legalización de firmas y documentos, y toda clase de escrituración pública con fe notarial indubitable.',
    detalles: [
      'Escrituras de compraventa y constitución',
      'Legalización de firmas y documentos',
      'Protocolización y autenticación notarial',
      'Mandatos y poderes de representación'
    ]
  },
  {
    icon: 'Landmark',
    titulo: 'Litigios Civiles',
    descripcion: 'Representación en tribunales para procesos ordinarios, sumarios, ejecutivos y resoluciones de disputas de alto impacto o cuantía.',
    detalles: [
      'Procesos ordinarios y sumarios',
      'Juicios ejecutivos y cobro de deudas',
      'Mediación y arbitraje comercial',
      'Resolución alternativa de conflictos'
    ]
  },
  {
    icon: 'Users',
    titulo: 'Derecho Laboral',
    descripcion: 'Prevención de conflictos patrono-trabajador, redacción de contratos, reglamentos internos y representación en juicios ordinarios laborales.',
    detalles: [
      'Contratos y reglamentos laborales',
      'Prevención de conflictos patrono-trabajador',
      'Representación en juicios laborales',
      'Auditoría de cumplimiento laboral'
    ]
  },
  {
    icon: 'Briefcase',
    titulo: 'Administrativo y Fiscal',
    descripcion: 'Asesoría ante entidades gubernativas, procesos sancionatorios, recursos administrativos, patentes y licencias de operación comercial e industrial.',
    detalles: [
      'Recursos y procesos administrativos',
      'Patentes y licencias comerciales',
      'Asesoría tributaria y fiscal',
      'Licitaciones y contrataciones públicas'
    ]
  }
];

const iconMap: Record<string, any> = { Landmark, ScrollText, Briefcase, Users, Building };
---

<BaseLayout 
  title="Servicios y Áreas de Práctica | Iuris&nbsp;Consultus"
  description="Conozca las especialidades legales en las que Iuris Consultus le puede asesorar: Bancario, Notarial, Civil, Laboral, Administrativo."
>

  <!-- Hero -->
  <!-- Hero -->
  <section class="bg-brand-dark pt-40 pb-20 md:pt-48 md:pb-32 text-center relative bg-scroll lg:bg-fixed bg-cover bg-center -mt-[74px]" style={`background-image: url('https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&q=80&w=2000');`}>
    <div class="absolute inset-0 bg-brand-dark/75 backdrop-blur-sm mix-blend-multiply"></div>
    <div class="container mx-auto px-6 relative z-10 text-white flex flex-col items-center">
      <p class="text-brand-accent font-bold tracking-[0.2em] uppercase text-xs mb-4 animate-reveal">Especialidades</p>
      <h1 class="text-4xl md:text-6xl font-bold font-serif mb-6 text-white animate-reveal" style="animation-delay: 100ms;">Áreas de Práctica</h1>
      <div class="section-divider mt-4 mb-6 animate-reveal" style="animation-delay: 200ms;"></div>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto font-light leading-relaxed animate-reveal" style="animation-delay: 300ms;">
        Asesoría especializada respaldada por décadas de experiencia e influencia en el marco jurídico nicaragüense.
      </p>
    </div>
  </section>

  <!-- Introduction -->
  <section class="pt-24 pb-12 bg-brand-light relative z-10">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row gap-12 lg:gap-16 items-center scroll-reveal">
        <div class="md:w-5/12 relative">
          <!-- Elemento decorativo top-left -->
          <div class="absolute -top-6 -left-6 w-16 h-16 border-t-4 border-l-4 border-brand-accent/30 rounded-tl-2xl z-0 hidden md:block"></div>
          
          <p class="text-brand-accent font-bold tracking-[0.2em] uppercase text-xs mb-4 relative z-10">Nuestra Promesa</p>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-serif text-brand-dark leading-tight relative z-10">
            Servicios Legales y<br />Resultados de Excelencia
          </h2>
          <div class="w-16 h-1 bg-brand-accent mt-6"></div>
        </div>
        <div class="md:w-7/12 flex flex-col justify-center">
          <div class="border-l-2 border-brand-accent/40 pl-6 py-2 bg-white/40 rounded-r-xl shadow-[0_2px_15px_rgba(0,0,0,0.02)]">
            <p class="text-brand-muted text-base lg:text-lg leading-relaxed mix-blend-multiply">
              Nuestro equipo de abogados especialistas analiza detalladamente cada aspecto de su situación para diseñar estrategias a la medida. Nos enfocamos no solo en la resolución inmediata, sino en estructurar un andamiaje legal robusto que blinde sus intereses y los de su empresa a futuro.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Practice Areas Grid -->
  <section class="pt-8 pb-24 bg-brand-light">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {areas.map((area, index) => {
          const IconComponent = iconMap[area.icon];
          return (
            <div class="scroll-reveal h-full" style={`transition-delay: ${index * 80}ms;`}>
              <div class="bg-white p-9 border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-sm group relative overflow-hidden flex flex-col h-full cursor-pointer">
                <!-- Decorative corner -->
                <div class="absolute top-0 right-0 w-24 h-24 bg-brand-accent/5 rounded-bl-[80px] z-0 transition-all group-hover:bg-brand-accent/10 group-hover:w-32 group-hover:h-32 pointer-events-none"></div>
                
                <div class="relative z-10 flex flex-col h-full">
                  <div class="w-14 h-14 bg-brand-primary text-brand-accent flex items-center justify-center rounded-sm mb-6 shadow-md group-hover:bg-brand-accent group-hover:text-white transition-colors duration-300 shrink-0">
                    {IconComponent && <IconComponent size={28} strokeWidth={1.5} />}
                  </div>
                  <h3 class="text-xl font-bold font-serif text-brand-dark mb-3">{area.titulo}</h3>
                  <p class="text-brand-muted leading-relaxed text-sm mb-6 line-clamp-3">{area.descripcion}</p>
                  
                  <div class="mt-auto">
                    <ul class="space-y-3">
                      {area.detalles.map(detalle => (
                        <li class="flex items-start gap-2 text-sm text-brand-muted">
                          <CheckCircle2 className="text-brand-accent shrink-0 mt-0.5" size={14} />
                          <span class="leading-snug line-clamp-2">{detalle}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          );
        })}

        <!-- CTA Card -->
        <div class="scroll-reveal h-full" style="transition-delay: 400ms;">
          <div class="bg-brand-primary p-9 shadow-xl rounded-sm flex flex-col h-full justify-center text-center relative overflow-hidden cursor-pointer group">
            <div class="absolute inset-0 opacity-10 pointer-events-none">
              <div class="absolute top-0 right-0 w-60 h-60 bg-brand-accent rounded-full blur-3xl group-hover:opacity-60 transition-opacity duration-500"></div>
              <div class="absolute bottom-0 left-0 w-40 h-40 bg-brand-accent rounded-full blur-3xl"></div>
            </div>
            <div class="relative z-10 flex flex-col h-full justify-center items-center">
              <div class="w-16 h-16 bg-white/10 text-brand-accent flex items-center justify-center rounded-sm mb-6 shadow-md group-hover:bg-brand-accent group-hover:text-white transition-all duration-500 group-hover:scale-110 shrink-0">
                <ShieldCheck size={32} strokeWidth={1.5} />
              </div>
              <h3 class="text-2xl font-bold font-serif text-white mb-4">Asesoría Preventiva</h3>
              <p class="text-white/70 text-sm mb-8 leading-relaxed max-w-xs mx-auto">
                Evite litigios costosos auditando sus contratos y operaciones actuales con nuestros expertos legales.
              </p>
              <a href="/contacto" class="inline-block bg-brand-accent text-white font-bold px-8 py-3.5 rounded-sm hover:bg-brand-accent-light transition-colors text-sm shadow-lg uppercase tracking-wider mt-auto cursor-pointer">
                Contáctenos Hoy
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us CTA -->
  <section class="py-24 bg-brand-warm">
    <div class="container mx-auto px-6">
      <div class="flex flex-col lg:flex-row items-center gap-16">
        <div class="lg:w-1/2 scroll-reveal-left">
          <p class="text-brand-accent font-bold tracking-[0.2em] uppercase text-xs mb-4">Diferenciadores</p>
          <h2 class="text-3xl md:text-4xl font-bold font-serif text-brand-primary mb-6 leading-tight">Un Enfoque Integral y Personalizado</h2>
          <p class="text-brand-muted text-lg leading-relaxed mb-6">
            No somos una firma genérica. Cada caso recibe la atención detallada y la estrategia personalizada que merece, respaldada por más de tres décadas de experiencia en el ordenamiento jurídico nicaragüense.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3">
              <div class="w-2 h-2 bg-brand-accent rounded-full shrink-0"></div>
              <span class="text-brand-dark font-medium text-sm">Asesoría bilingüe (español e inglés)</span>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-2 h-2 bg-brand-accent rounded-full shrink-0"></div>
              <span class="text-brand-dark font-medium text-sm">Equipo multidisciplinario especializado</span>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-2 h-2 bg-brand-accent rounded-full shrink-0"></div>
              <span class="text-brand-dark font-medium text-sm">Amplia red de contactos institucionales</span>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-2 h-2 bg-brand-accent rounded-full shrink-0"></div>
              <span class="text-brand-dark font-medium text-sm">Confidencialidad absoluta garantizada</span>
            </li>
          </ul>
          <a href="/contacto" class="inline-flex items-center gap-2 bg-brand-primary text-white px-8 py-3.5 rounded-sm font-bold hover:bg-brand-secondary transition-colors shadow-md text-sm uppercase tracking-wider cursor-pointer">
            Consulta Gratuita <ArrowRight size={16} />
          </a>
        </div>
        <div class="lg:w-1/2 scroll-reveal-right">
          <div class="bg-white p-8 rounded-sm shadow-lg border-l-4 border-brand-accent">
            <blockquote class="text-brand-muted text-lg leading-relaxed italic font-serif">
              «La excelencia no es un acto, sino un hábito. En Iuris Consultus, cada detalle legal importa.»
            </blockquote>
            <div class="mt-6 flex items-center gap-3">
              <div class="w-10 h-1 bg-brand-accent"></div>
              <span class="text-brand-dark font-bold text-sm">Iuris Consultus</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
