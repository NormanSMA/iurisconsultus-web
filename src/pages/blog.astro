---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { getCollection } from 'astro:content';
import { CalendarDays, ArrowRight, BookOpen, Scale, FileText } from 'lucide-react';

const todasLasEntradas = await getCollection('blog', ({ data }) => data.publicado !== false);
const noticias = todasLasEntradas.sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());

const EXCERPT_LIMIT = 150;

function formatearFecha(fecha: Date): string {
  return fecha.toLocaleDateString('es-NI', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function truncarTexto(texto: string): string {
  const limpio = texto.replace(/[#*_`>-]/g, '').trim();
  return limpio.length > EXCERPT_LIMIT ? limpio.slice(0, EXCERPT_LIMIT) + '…' : limpio;
}

const featured = noticias[0];
const restArticles = noticias.slice(1);
---

<BaseLayout
  title="Blog Jurídico | Iuris&nbsp;Consultus"
  description="Manténgase actualizado con artículos legales, opiniones jurídicas y noticias de Iuris Consultus en Nicaragua."
>

  
  
  
  <section class="bg-brand-dark pt-40 pb-20 md:pt-48 md:pb-32 text-center relative bg-scroll lg:bg-fixed bg-cover bg-center -mt-[74px]" style="background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?auto=format&fit=crop&q=85&w=2000');">
    <div class="absolute inset-0 bg-brand-dark/80"></div>
    <div class="container mx-auto px-6 relative z-10 text-white flex flex-col items-center">
      <p class="text-brand-accent font-bold tracking-[0.2em] uppercase text-xs mb-4 animate-reveal">Blog Jurídico</p>
      <h1 class="text-4xl md:text-6xl font-bold font-serif mb-6 text-white animate-reveal" style="animation-delay: 100ms;">Análisis &amp; Opinión Legal</h1>
      <div class="section-divider mt-4 mb-6 animate-reveal" style="animation-delay: 200ms;"></div>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto font-light leading-relaxed animate-reveal" style="animation-delay: 300ms;">
        Manténgase informado con los análisis y opiniones jurídicas de nuestros especialistas.
      </p>
    </div>
  </section>

  
  
  
  <section class="bg-brand-light py-16">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { icon: BookOpen, title: "Análisis Legal", text: "Interpretamos reformas y sentencias con profundidad jurídica y claridad práctica.", delay: 0 },
          { icon: Scale, title: "Jurisprudencia", text: "Seguimiento de precedentes que impactan su empresa o situación personal.", delay: 100 },
          { icon: FileText, title: "Reformas & Noticias", text: "Actualizaciones legislativas relevantes para el ámbito corporativo y notarial.", delay: 200 },
        ].map(({ icon: Icon, title, text, delay }) => (
          <div class="scroll-reveal" style={`transition-delay: ${delay}ms`}>
            <div class="feature-card group bg-white p-9 rounded-sm border-b-2 border-brand-accent/40 shadow-md hover:shadow-2xl transition-all duration-300 cursor-default h-full relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-0.5 feature-card-bar transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
              <div class="w-12 h-12 bg-brand-primary/8 rounded-sm flex items-center justify-center mb-6 text-brand-accent group-hover:bg-brand-accent group-hover:text-white transition-all duration-300">
                <Icon size={26} strokeWidth={1.5} />
              </div>
              <h3 class="text-lg font-bold font-serif mb-3 text-brand-dark">{title}</h3>
              <p class="text-brand-muted leading-relaxed text-sm">{text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  
  
  
  <section class="py-16 md:py-24 bg-brand-light">
    <div class="container mx-auto px-6">

      
      <div class="scroll-reveal mb-16">
        <div class="section-label-row mb-8">
          <span></span>
          <p class="text-brand-accent font-bold tracking-[0.25em] uppercase text-[11px]">Artículo Destacado</p>
          <span></span>
        </div>

        <a href={'/blog/' + featured.slug} class="group bg-white rounded-sm shadow-md overflow-hidden flex flex-col lg:flex-row border border-transparent hover:border-brand-accent/15 hover:shadow-xl transition-all duration-400 cursor-pointer">
          
          <div class="lg:w-[45%] h-56 lg:h-auto overflow-hidden relative shrink-0">
            <img
              src={featured.data.imagen}
              alt={featured.data.titulo}
              loading="eager"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              width="600" height="380"
            />
            <div class="featured-corner absolute bottom-0 left-0 w-12 h-12 pointer-events-none"></div>
          </div>

          
          <div class="lg:w-[55%] p-7 lg:p-10 flex flex-col justify-center">
            <time class="flex items-center gap-2 text-xs text-gray-500 font-medium mb-4">
              <CalendarDays size={12} className="text-brand-accent" />
              {formatearFecha(featured.data.fecha)}
            </time>
            <h2 class="font-serif font-bold text-xl md:text-2xl text-brand-dark leading-snug mb-3 group-hover:text-brand-primary transition-colors duration-300">
              {featured.data.titulo}
            </h2>
            <div class="w-8 h-0.5 bg-brand-accent mb-4"></div>

            
            <p class="text-gray-600 leading-relaxed text-sm mb-5">
              {truncarTexto(featured.body)}
            </p>
          </div>
        </a>
      </div>

      
      <div class="section-label-row mb-8">
        <span></span>
        <p class="text-brand-accent font-bold tracking-[0.25em] uppercase text-[11px]">Publicaciones Recientes</p>
        <span></span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
        {restArticles.map((articulo, index) => {
          return (
            <div class="scroll-reveal" style={`transition-delay: ${index * 80}ms`}>
              <article class="touch-card group bg-white rounded-sm overflow-hidden flex flex-col h-full border border-gray-100 hover:border-brand-accent/20 hover:shadow-xl transition-all duration-300">
                <a href={`/blog/${articulo.slug}`} class="block relative overflow-hidden" style="height: 200px;">
                  <img
                    src={articulo.data.imagen}
                    alt={articulo.data.titulo}
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    width="480" height="200"
                  />
                  <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(7,9,25,0.75) 0%, rgba(7,9,25,0.2) 50%, transparent 100%);"></div>
                  {articulo.data.area && (
                    <span class="absolute top-3 left-3 bg-brand-accent text-white text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-sm">
                      {articulo.data.area}
                    </span>
                  )}
                  <time class="absolute bottom-3 left-3 flex items-center gap-1.5 text-white/80 text-[11px] font-medium">
                    <CalendarDays size={10} className="text-brand-accent" />
                    {articulo.data.fecha.toLocaleDateString('es-NI', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </time>
                </a>
                <div class="p-5 flex flex-col grow">
                  <h3 class="font-serif font-bold text-[0.95rem] text-brand-dark leading-snug mb-3 group-hover:text-brand-primary transition-colors duration-300 grow">
                    <a href={`/blog/${articulo.slug}`}>{articulo.data.titulo}</a>
                  </h3>
                  <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
                    <div class="w-6 h-0.5 bg-brand-accent/50 group-hover:w-10 transition-all duration-300"></div>
                    <a href={`/blog/${articulo.slug}`} class="inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-wider text-brand-accent hover:text-brand-primary transition-colors duration-200 group-hover:gap-2.5">
                      Leer más
                      <ArrowRight size={11} />
                    </a>
                  </div>
                </div>
              </article>
            </div>
          );
        })}
      </div>

    </div>
  </section>


  
  
  
  <section class="bg-brand-primary py-16 md:py-20 relative overflow-hidden">
    
    <div class="absolute top-0 left-1/3 w-80 h-80 bg-brand-accent/8 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-48 h-48 bg-brand-accent/5 rounded-full blur-2xl pointer-events-none"></div>
    
    <div class="absolute top-0 left-0 right-0 h-0.5 blog-gold-line"></div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        
        <div class="text-white">
          <p class="text-brand-accent font-bold tracking-[0.28em] uppercase text-xs mb-5 flex items-center gap-3">
            <span class="inline-block w-6 h-px bg-brand-accent"></span>
            Desde 1991
          </p>
          <h2 class="font-serif font-bold text-3xl md:text-4xl leading-tight mb-5 text-white">
            Su situación legal<br/>
            <span class="text-brand-accent italic">merece atención experta.</span>
          </h2>
          <div class="w-10 h-0.5 bg-brand-accent mb-6"></div>
          <p class="text-white/70 text-base leading-relaxed mb-4">
            En Iuris Consultus encontrará un equipo dedicado, discreto y comprometido con los resultados que usted necesita. Más de tres décadas brindando soluciones jurídicas inigualables en Nicaragua y Centroamérica.
          </p>
          <p class="text-white/50 text-sm leading-relaxed italic">
            Cada caso es único. Cada cliente, una prioridad.
          </p>
        </div>

        
        <div class="border-l-2 border-brand-accent/35 pl-8 lg:pl-12">
          <div class="text-brand-accent text-5xl font-serif leading-none mb-3 opacity-25 select-none">"</div>
          <blockquote class="text-white/80 text-lg md:text-xl font-light italic leading-relaxed font-serif mb-6">
            El conocimiento del derecho no es suficiente. La experiencia, la ética y el compromiso son los que marcan la diferencia.
          </blockquote>
          <p class="text-brand-accent/60 text-xs uppercase tracking-widest mb-10 font-semibold">— Filosofía Iuris Consultus</p>

          <Button href="/contacto" variant="gold" group>
            Contáctenos
            <ArrowRight size={16} />
          </Button>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>

.blog-gold-line {
  background: linear-gradient(90deg, transparent 0%, var(--color-brand-accent, #b8960c) 30%, var(--color-brand-accent, #b8960c) 70%, transparent 100%);
}


.section-label-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.section-label-row span {
  display: block;
  height: 1px;
  background: rgba(0,0,0,0.12);
  flex: 1;
}
.section-label-row span:first-child {
  max-width: 32px;
}


.featured-corner {
  background: linear-gradient(135deg, var(--color-brand-accent, #b8960c) 0%, transparent 55%);
  opacity: 0.4;
}


.duration-400 { transition-duration: 400ms; }


@keyframes reveal {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.animate-reveal { animation: reveal 0.7s ease forwards; }


</style>

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const el = entry.target as HTMLElement;
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
      observer.unobserve(el);
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll<HTMLElement>('.scroll-reveal').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(22px)';
  el.style.transition = `opacity 0.55s ease, transform 0.55s ease`;
  observer.observe(el);
});
</script>

