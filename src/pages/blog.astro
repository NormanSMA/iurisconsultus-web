---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CalendarDays, ArrowRight, BookOpen, Scale, FileText } from 'lucide-react';

const todasLasEntradas = await getCollection('blog', ({ data }) => data.publicado !== false);
const noticias = todasLasEntradas.sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());

const EXCERPT_LIMIT = 150;

function formatearFecha(fecha: Date): string {
  return fecha.toLocaleDateString('es-NI', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function truncarTexto(texto: string): string {
  const limpio = texto.replace(/[#*_`>-]/g, '').trim();
  return limpio.length > EXCERPT_LIMIT ? limpio.slice(0, EXCERPT_LIMIT) + '…' : limpio;
}

const featured = noticias[0];
const restArticles = noticias.slice(1);
---

<BaseLayout
  title="Blog Jurídico | Iuris&nbsp;Consultus"
  description="Manténgase actualizado con artículos legales, opiniones jurídicas y noticias de Iuris Consultus en Nicaragua."
>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- HERO                                                            -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section
    class="relative overflow-hidden flex items-center justify-center text-center -mt-[74px]"
    style="min-height: 60vh;"
  >
    <div
      class="absolute inset-0 w-full h-full z-0 hero-bg-blog"
      style="background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?auto=format&fit=crop&q=85&w=2000'); background-size: cover; background-position: center;"
    ></div>

    <!-- Dark overlay -->
    <div class="absolute inset-0 z-10" style="background: rgba(5,8,28,0.82);"></div>
    <!-- Very thin bottom edge — not a big white splash -->
    <div class="absolute bottom-0 left-0 right-0 h-8 z-10" style="background: linear-gradient(to bottom, transparent, rgba(245,242,234,0.6));"></div>
    <!-- Gold accent bar left -->
    <div class="absolute left-0 top-0 bottom-0 w-1 hidden lg:block z-20" style="background: linear-gradient(to bottom, transparent 5%, var(--color-brand-accent, #b8960c) 25%, var(--color-brand-accent, #b8960c) 75%, transparent 95%); opacity: 0.45;"></div>

    <!-- Content — left aligned, clear of header -->
    <div class="container mx-auto px-6 relative z-20 text-white pt-44 pb-20">
      <div class="max-w-2xl animate-reveal">
        <p class="text-brand-accent font-bold tracking-[0.3em] uppercase text-xs mb-6 flex items-center gap-3">
          <span class="inline-block w-8 h-px bg-brand-accent"></span>
          Blog Jurídico · Publicaciones
        </p>
        <h1 class="font-serif font-bold text-4xl md:text-5xl lg:text-6xl leading-[1.08] drop-shadow-2xl text-white">
          Análisis
          <span class="block text-brand-accent italic font-medium text-3xl md:text-4xl lg:text-5xl mt-2">&amp; Opinión Legal</span>
        </h1>
        <div class="flex items-center gap-4 mt-6">
          <span class="w-10 h-px bg-brand-accent"></span>
          <span class="w-2 h-2 rounded-full bg-brand-accent opacity-60"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- INTRO STRIP — 3 pilares, sin stats (ya están en el inicio)     -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-14 border-b border-gray-100 relative">
    <div class="absolute top-0 left-0 right-0 h-0.5 blog-gold-line"></div>

    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">

        <div class="flex flex-col items-center gap-3 px-4">
          <div class="w-11 h-11 rounded-sm bg-brand-accent/10 flex items-center justify-center text-brand-accent">
            <BookOpen size={20} strokeWidth={1.5} />
          </div>
          <h3 class="font-serif font-bold text-brand-dark text-base">Análisis Legal</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Interpretamos reformas y sentencias con profundidad jurídica y claridad práctica.
          </p>
        </div>

        <div class="flex flex-col items-center gap-3 px-4">
          <div class="w-11 h-11 rounded-sm bg-brand-accent/10 flex items-center justify-center text-brand-accent">
            <Scale size={20} strokeWidth={1.5} />
          </div>
          <h3 class="font-serif font-bold text-brand-dark text-base">Jurisprudencia</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Seguimiento de precedentes que impactan su empresa o situación personal.
          </p>
        </div>

        <div class="flex flex-col items-center gap-3 px-4">
          <div class="w-11 h-11 rounded-sm bg-brand-accent/10 flex items-center justify-center text-brand-accent">
            <FileText size={20} strokeWidth={1.5} />
          </div>
          <h3 class="font-serif font-bold text-brand-dark text-base">Reformas & Noticias</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Actualizaciones legislativas relevantes para el ámbito corporativo y notarial.
          </p>
        </div>

      </div>
      <!-- Gold divider -->
      <div class="blog-gold-line-divider mt-10 mx-auto"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- ARTÍCULOS                                                       -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 bg-brand-light">
    <div class="container mx-auto px-6">

      <!-- ─── Artículo destacado ─────────────────────────────────── -->
      <div class="scroll-reveal mb-16">
        <div class="section-label-row mb-8">
          <span></span>
          <p class="text-brand-accent font-bold tracking-[0.25em] uppercase text-[11px]">Artículo Destacado</p>
          <span></span>
        </div>

        <a href={'/blog/' + featured.slug} class="group bg-white rounded-sm shadow-md overflow-hidden flex flex-col lg:flex-row border border-transparent hover:border-brand-accent/15 hover:shadow-xl transition-all duration-400 cursor-pointer">
          <!-- Image -->
          <div class="lg:w-[45%] h-56 lg:h-auto overflow-hidden relative shrink-0">
            <img
              src={featured.data.imagen}
              alt={featured.data.titulo}
              loading="eager"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              width="600" height="380"
            />
            <div class="featured-corner absolute bottom-0 left-0 w-12 h-12 pointer-events-none"></div>
          </div>

          <!-- Content -->
          <div class="lg:w-[55%] p-7 lg:p-10 flex flex-col justify-center">
            <time class="flex items-center gap-2 text-xs text-gray-500 font-medium mb-4">
              <CalendarDays size={12} className="text-brand-accent" />
              {formatearFecha(featured.data.fecha)}
            </time>
            <h2 class="font-serif font-bold text-xl md:text-2xl text-brand-dark leading-snug mb-3 group-hover:text-brand-primary transition-colors duration-300">
              {featured.data.titulo}
            </h2>
            <div class="w-8 h-0.5 bg-brand-accent mb-4"></div>

            <!-- Texto expandible — usando data-attributes -->
            <p
              class="featured-text text-gray-600 leading-relaxed text-sm mb-5"
              data-short={truncarTexto(featured.body)}
              data-full={truncarTexto(featured.body)}
              data-truncated="false"
            >
              {truncarTexto(featured.body)}
            </p>
          </div>
        </a>
      </div>

      <!-- ─── Grid de publicaciones ──────────────────────────────── -->
      <div class="section-label-row mb-8">
        <span></span>
        <p class="text-brand-accent font-bold tracking-[0.25em] uppercase text-[11px]">Publicaciones Recientes</p>
        <span></span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
        {restArticles.map((articulo, index) => {
          return (
            <div class="scroll-reveal" style={`transition-delay: ${index * 80}ms`}>
              <a href={'/blog/' + articulo.slug} class="group bg-white rounded-sm border border-gray-100 overflow-hidden flex flex-col h-full hover:shadow-xl hover:border-brand-accent/20 transition-all duration-400">

                <!-- Imagen -->
                <div class="h-48 overflow-hidden relative shrink-0">
                  <img
                    src={articulo.data.imagen}
                    alt={articulo.data.titulo}
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    width="480" height="192"
                  />
                </div>

                <!-- Contenido -->
                <div class="p-6 flex flex-col grow">
                  <time class="flex items-center gap-1.5 text-[11px] text-gray-500 font-medium mb-3">
                    <CalendarDays size={11} className="text-brand-accent" />
                    {formatearFecha(articulo.data.fecha)}
                  </time>

                  <h3 class="font-serif font-bold text-[1rem] text-brand-dark leading-snug mb-3 group-hover:text-brand-primary transition-colors duration-300">
                    {articulo.data.titulo}
                  </h3>

                  <div class="w-6 h-0.5 bg-brand-accent/60 mb-4 group-hover:w-10 transition-all duration-400 ease-out"></div>

                  <!-- Texto expandible via data-attributes -->
                  <p
                    class="ver-mas-text text-gray-600 text-sm leading-relaxed mb-4 grow"
                    data-short={truncarTexto(articulo.body)}
                    data-full={truncarTexto(articulo.body)}
                    data-truncated="false"
                  >
                    {truncarTexto(articulo.body)}
                  </p>
                </div>
              </a>
            </div>
          );
        })}
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- CIERRE — Editorial split, sección de cierre                    -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="bg-brand-primary py-16 md:py-20 relative overflow-hidden">
    <!-- Decorative glows -->
    <div class="absolute top-0 left-1/3 w-80 h-80 bg-brand-accent/8 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-48 h-48 bg-brand-accent/5 rounded-full blur-2xl pointer-events-none"></div>
    <!-- Gold top line -->
    <div class="absolute top-0 left-0 right-0 h-0.5 blog-gold-line"></div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Izquierda: texto editorial descriptivo -->
        <div class="text-white">
          <p class="text-brand-accent font-bold tracking-[0.28em] uppercase text-xs mb-5 flex items-center gap-3">
            <span class="inline-block w-6 h-px bg-brand-accent"></span>
            Desde 1991
          </p>
          <h2 class="font-serif font-bold text-3xl md:text-4xl leading-tight mb-5">
            Su situación legal<br/>
            <span class="text-brand-accent italic">merece atención experta.</span>
          </h2>
          <div class="w-10 h-0.5 bg-brand-accent mb-6"></div>
          <p class="text-white/70 text-base leading-relaxed mb-4">
            En Iuris Consultus encontrará un equipo dedicado, discreto y comprometido con los resultados que usted necesita. Más de tres décadas brindando soluciones jurídicas inigualables en Nicaragua y Centroamérica.
          </p>
          <p class="text-white/50 text-sm leading-relaxed italic">
            Cada caso es único. Cada cliente, una prioridad.
          </p>
        </div>

        <!-- Derecha: cita destacada + CTA -->
        <div class="border-l-2 border-brand-accent/35 pl-8 lg:pl-12">
          <div class="text-brand-accent text-5xl font-serif leading-none mb-3 opacity-25 select-none">"</div>
          <blockquote class="text-white/80 text-lg md:text-xl font-light italic leading-relaxed font-serif mb-6">
            El conocimiento del derecho no es suficiente. La experiencia, la ética y el compromiso son los que marcan la diferencia.
          </blockquote>
          <p class="text-brand-accent/60 text-xs uppercase tracking-widest mb-10 font-semibold">— Filosofía Iuris Consultus</p>

          <a href="/contacto" class="inline-flex items-center gap-2 bg-brand-accent text-white font-bold px-8 py-3.5 rounded-sm hover:bg-brand-accent-light transition-colors text-sm shadow-lg uppercase tracking-wider cursor-pointer">
            Contáctenos
            <ArrowRight size={16} />
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* Gold lines */
.blog-gold-line {
  background: linear-gradient(90deg, transparent 0%, var(--color-brand-accent, #b8960c) 30%, var(--color-brand-accent, #b8960c) 70%, transparent 100%);
}
.blog-gold-line-divider {
  height: 2px;
  max-width: 420px;
  border-radius: 1px;
  background: linear-gradient(90deg, transparent 0%, var(--color-brand-accent, #b8960c) 30%, var(--color-brand-accent, #b8960c) 70%, transparent 100%);
}

/* Section label row */
.section-label-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.section-label-row span {
  display: block;
  height: 1px;
  background: rgba(0,0,0,0.12);
  flex: 1;
}
.section-label-row span:first-child {
  max-width: 32px;
}

/* Featured corner */
.featured-corner {
  background: linear-gradient(135deg, var(--color-brand-accent, #b8960c) 0%, transparent 55%);
  opacity: 0.4;
}

/* Ver más button */
.ver-mas-btn {
  color: var(--color-brand-accent, #b8960c);
  background: none;
  border: none;
  padding: 0;
  font-family: inherit;
  transition: color 0.25s;
}
.ver-mas-btn:hover {
  color: var(--color-brand-primary, #0c1836);
}
.ver-mas-btn:hover .btn-circle {
  background-color: var(--color-brand-primary, #0c1836);
  transform: translateX(2px);
}
.btn-circle {
  flex-shrink: 0;
  transition: background-color 0.3s, transform 0.25s;
}

/* Transitions */
.duration-400 { transition-duration: 400ms; }

/* Hero reveal */
@keyframes reveal {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.animate-reveal { animation: reveal 0.7s ease forwards; }

/* ── Hero parallax — solo desktop con mouse ── */
.hero-bg-blog {
  background-attachment: scroll;
}
@media (min-width: 1024px) and (hover: hover) {
  .hero-bg-blog {
    background-attachment: fixed;
  }
}
</style>

<script>
// ── Ver más / Ver menos — usa data-attributes, sin clases dinámicas ──
document.querySelectorAll<HTMLButtonElement>('.ver-mas-btn').forEach(btn => {
  let expanded = false;

  btn.addEventListener('click', (e) => {
    e.preventDefault();
    expanded = !expanded;

    // Busca el párrafo de texto dentro del mismo contenedor
    const container = btn.closest('article') ?? btn.parentElement;
    const textEl = container?.querySelector<HTMLParagraphElement>(
      '.featured-text, .ver-mas-text'
    );
    const label = btn.querySelector('.btn-label');
    const circle = btn.querySelector('.btn-circle');

    if (!textEl) return;

    if (expanded) {
      textEl.textContent = textEl.dataset.full ?? '';
      if (label) label.textContent = 'Ver menos';
      if (circle) (circle as HTMLElement).style.transform = 'rotate(90deg)';
    } else {
      textEl.textContent = textEl.dataset.short ?? '';
      if (label) {
        label.textContent = btn.closest('article')?.querySelector('.featured-text')
          ? 'Leer artículo completo'
          : 'Ver más';
      }
      if (circle) (circle as HTMLElement).style.transform = '';
    }
  });
});

// ── Scroll reveal ──────────────────────────────────────────────────
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const el = entry.target as HTMLElement;
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
      observer.unobserve(el);
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll<HTMLElement>('.scroll-reveal').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(22px)';
  el.style.transition = `opacity 0.55s ease, transform 0.55s ease`;
  observer.observe(el);
});
</script>
