---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CalendarDays, ArrowRight, Clock } from 'lucide-react';

const noticias = [
  {
    titulo: "Nuevas Reformas al Código de Comercio: Lo que su empresa debe saber",
    fecha: "20 Octubre, 2026",
    resumen: "Un análisis detallado de las recientes modificaciones aprobadas por el congreso que impactan la forma en que las SA deben reportar sus estados financieros anuales.",
    imagen: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&q=80&w=800",
    categoria: "Corporativo",
    lectura: "5 min"
  },
  {
    titulo: "Guía para la Resolución Alternativa de Conflictos en Contratos",
    fecha: "15 Octubre, 2026",
    resumen: "Descubra cómo las cláusulas de arbitraje y mediación pueden ahorrar tiempo y dinero a su corporación frente a disputas contractuales complejas.",
    imagen: "https://images.unsplash.com/photo-1521791055366-0d553872125f?auto=format&fit=crop&q=80&w=800",
    categoria: "Civil",
    lectura: "7 min"
  },
  {
    titulo: "Consecuencias Legales del Incumplimiento Laboral post-pandemia",
    fecha: "02 Octubre, 2026",
    resumen: "Revisamos sentencias recientes que sientan jurisprudencia sobre el teletrabajo y los derechos adquiridos por los empleados durante modalidades híbridas.",
    imagen: "https://images.unsplash.com/photo-1507925921958-8a62f3d1a50d?auto=format&fit=crop&q=80&w=800",
    categoria: "Laboral",
    lectura: "6 min"
  },
  {
    titulo: "Obligaciones Fiscales para Inversiones Extranjeras en Nicaragua",
    fecha: "18 Septiembre, 2026",
    resumen: "Analizamos el régimen tributario aplicable a inversiones extranjeras, incluyendo incentivos fiscales, exenciones y los requisitos de registro ante el MIFIC.",
    imagen: "https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&q=80&w=800",
    categoria: "Fiscal",
    lectura: "8 min"
  },
  {
    titulo: "Protección de Propiedad Intelectual en el Mercado Centroamericano",
    fecha: "05 Septiembre, 2026",
    resumen: "Una guía práctica sobre el registro de marcas, patentes y derechos de autor ante las autoridades competentes de la región para proteger sus activos intangibles.",
    imagen: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&q=80&w=800",
    categoria: "Corporativo",
    lectura: "6 min"
  },
  {
    titulo: "Reformas al Código Procesal Civil: Plazos y Nuevas Reglas 2026",
    fecha: "22 Agosto, 2026",
    resumen: "Las reformas procesales más significativas del año modifican los plazos de contestación de demandas, criterios de admisibilidad probatoria y recursos de apelación.",
    imagen: "https://images.unsplash.com/photo-1505664194779-8beaceb93744?auto=format&fit=crop&q=80&w=800",
    categoria: "Civil",
    lectura: "9 min"
  }
];

const featured = noticias[0];
const rest = noticias.slice(1);
---

<BaseLayout 
  title="Blog Jurídico | Iuris&nbsp;Consultus"
  description="Manténgase actualizado con artículos legales, opiniones jurídicas y noticias de Iuris Consultus en Nicaragua."
>
  
  <!-- Hero -->
  <section class="bg-brand-dark py-32 md:py-40 text-center relative bg-fixed bg-cover bg-center -mt-[calc(0.125rem+4.5rem)]" style={`background-image: url('https://images.unsplash.com/photo-1481627834876-b7833e8f5570?auto=format&fit=crop&q=80&w=2000');`}>
    <div class="absolute inset-0 bg-brand-dark/88 mix-blend-multiply"></div>
    <div class="container mx-auto px-6 relative z-10 text-white animate-reveal">
      <p class="text-brand-accent font-bold tracking-[0.2em] uppercase text-xs mb-4">Publicaciones</p>
      <h1 class="text-4xl md:text-6xl font-bold font-serif mb-6">Blog Jurídico</h1>
      <div class="section-divider mt-4 mb-6"></div>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto font-light leading-relaxed">
        Actualidad, opiniones expertas y reformas legales analizadas por nuestros profesionales.
      </p>
    </div>
  </section>

  <!-- Featured Article -->
  <section class="py-24 bg-brand-light">
    <div class="container mx-auto px-6">
      
      <!-- Featured -->
      <div class="scroll-reveal mb-16">
        <article class="bg-white rounded-sm shadow-sm overflow-hidden group hover:shadow-xl transition-all duration-300 cursor-pointer flex flex-col lg:flex-row">
          <div class="lg:w-1/2 h-64 lg:h-auto overflow-hidden relative">
            <div class="absolute top-4 left-4 bg-brand-accent text-white text-[10px] font-bold px-3 py-1.5 rounded-sm z-10 uppercase tracking-[0.2em]">
              {featured.categoria}
            </div>
            <img src={featured.imagen} alt={featured.titulo} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" width="600" height="400" />
          </div>
          <div class="lg:w-1/2 p-8 lg:p-12 flex flex-col justify-center">
            <div class="flex items-center gap-4 text-sm text-brand-slate mb-4">
              <span class="flex items-center gap-1.5">
                <CalendarDays size={14} class="text-brand-accent" />
                <time>{featured.fecha}</time>
              </span>
              <span class="flex items-center gap-1.5">
                <Clock size={14} class="text-brand-accent" />
                {featured.lectura} de lectura
              </span>
            </div>
            <h2 class="text-2xl md:text-3xl font-bold font-serif text-brand-dark mb-4 leading-tight group-hover:text-brand-primary transition-colors">
              <a href="#">{featured.titulo}</a>
            </h2>
            <p class="text-brand-muted leading-relaxed mb-6">{featured.resumen}</p>
            <a href="#" class="inline-flex items-center gap-2 text-brand-accent font-bold text-sm tracking-wider uppercase hover:text-brand-accent-light transition-colors cursor-pointer group/btn">
              Leer Artículo <ArrowRight size={16} class="group-hover/btn:translate-x-1 transition-transform" />
            </a>
          </div>
        </article>
      </div>

      <!-- Articles + Sidebar Layout -->
      <div class="flex flex-col lg:flex-row gap-12">
        
        <!-- Articles Grid -->
        <div class="lg:w-2/3">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {rest.map((articulo, index) => (
              <article class="scroll-reveal bg-white rounded-sm shadow-sm border border-gray-100 overflow-hidden group hover:shadow-lg transition-all duration-300 cursor-pointer" style={`transition-delay: ${index * 80}ms;`}>
                <div class="h-48 overflow-hidden relative">
                  <div class="absolute top-4 left-4 bg-brand-accent text-white text-[10px] font-bold px-3 py-1.5 rounded-sm z-10 uppercase tracking-[0.2em]">
                    {articulo.categoria}
                  </div>
                  <img src={articulo.imagen} alt={articulo.titulo} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="400" height="192" />
                </div>
                
                <div class="p-6">
                  <div class="flex items-center gap-4 text-xs text-brand-slate mb-3">
                    <span class="flex items-center gap-1.5">
                      <CalendarDays size={12} class="text-brand-accent" />
                      <time>{articulo.fecha}</time>
                    </span>
                    <span class="flex items-center gap-1.5">
                      <Clock size={12} class="text-brand-accent" />
                      {articulo.lectura}
                    </span>
                  </div>
                  
                  <h3 class="text-lg font-bold font-serif text-brand-dark mb-3 leading-snug group-hover:text-brand-primary transition-colors">
                    <a href="#">{articulo.titulo}</a>
                  </h3>
                  
                  <p class="text-brand-muted text-sm leading-relaxed mb-5">
                    {articulo.resumen}
                  </p>
                  
                  <a href="#" class="text-brand-accent font-bold text-xs tracking-[0.15em] uppercase hover:text-brand-accent-light transition-colors flex items-center gap-1.5 cursor-pointer group/btn">
                    Leer Artículo <ArrowRight size={14} class="group-hover/btn:translate-x-1 transition-transform" />
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:w-1/3 space-y-8">
          
          <!-- Newsletter -->
          <div class="scroll-reveal bg-brand-primary text-white p-8 rounded-sm shadow-lg relative overflow-hidden">
            <div class="absolute inset-0 opacity-10">
              <div class="absolute top-0 right-0 w-40 h-40 bg-brand-accent rounded-full blur-3xl"></div>
            </div>
            <div class="relative z-10">
              <h3 class="text-xl font-bold font-serif mb-3">Boletín Legal</h3>
              <p class="text-white/70 text-sm leading-relaxed mb-6">Suscríbase para recibir alertas sobre cambios legislativos directamente en su correo.</p>
              <form class="flex flex-col gap-3" onsubmit="event.preventDefault(); alert('¡Suscripción exitosa! Recibirá nuestro próximo boletín.');">
                <input type="email" placeholder="Su correo electrónico" required class="px-4 py-3 rounded-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-brand-accent w-full text-sm bg-white" />
                <button class="bg-brand-accent text-white font-bold py-3 uppercase tracking-wider rounded-sm hover:bg-brand-accent-light transition-all duration-300 cursor-pointer w-full text-xs shadow-md">Suscribirse</button>
              </form>
            </div>
          </div>

          <!-- Categories -->
          <div class="scroll-reveal bg-white p-8 border border-gray-100 rounded-sm shadow-sm" style="transition-delay: 100ms;">
            <h3 class="text-lg font-bold font-serif text-brand-dark mb-6 pb-3 border-b border-gray-200 relative">
              Categorías
              <span class="absolute bottom-0 left-0 w-8 h-0.5 bg-brand-accent"></span>
            </h3>
            <ul class="space-y-3">
              <li><a href="#" class="flex justify-between items-center text-brand-muted hover:text-brand-accent transition-colors cursor-pointer py-1"><span class="font-medium text-sm">Corporativo</span> <span class="text-xs bg-brand-warm px-2.5 py-1 rounded-full text-brand-slate">12</span></a></li>
              <li><a href="#" class="flex justify-between items-center text-brand-muted hover:text-brand-accent transition-colors cursor-pointer py-1"><span class="font-medium text-sm">Civil y Mercantil</span> <span class="text-xs bg-brand-warm px-2.5 py-1 rounded-full text-brand-slate">8</span></a></li>
              <li><a href="#" class="flex justify-between items-center text-brand-muted hover:text-brand-accent transition-colors cursor-pointer py-1"><span class="font-medium text-sm">Notarial</span> <span class="text-xs bg-brand-warm px-2.5 py-1 rounded-full text-brand-slate">5</span></a></li>
              <li><a href="#" class="flex justify-between items-center text-brand-muted hover:text-brand-accent transition-colors cursor-pointer py-1"><span class="font-medium text-sm">Laboral</span> <span class="text-xs bg-brand-warm px-2.5 py-1 rounded-full text-brand-slate">10</span></a></li>
              <li><a href="#" class="flex justify-between items-center text-brand-muted hover:text-brand-accent transition-colors cursor-pointer py-1"><span class="font-medium text-sm">Bancario y Financiero</span> <span class="text-xs bg-brand-warm px-2.5 py-1 rounded-full text-brand-slate">7</span></a></li>
              <li><a href="#" class="flex justify-between items-center text-brand-muted hover:text-brand-accent transition-colors cursor-pointer py-1"><span class="font-medium text-sm">Fiscal</span> <span class="text-xs bg-brand-warm px-2.5 py-1 rounded-full text-brand-slate">4</span></a></li>
            </ul>
          </div>

          <!-- Quick Contact -->
          <div class="scroll-reveal bg-brand-warm p-8 rounded-sm border border-brand-warm-dark" style="transition-delay: 200ms;">
            <h3 class="text-lg font-bold font-serif text-brand-dark mb-3">¿Tiene una consulta legal?</h3>
            <p class="text-brand-muted text-sm mb-5 leading-relaxed">Nuestro equipo está disponible para atender su caso con absoluta confidencialidad.</p>
            <a href="/contacto" class="inline-flex items-center gap-2 bg-brand-primary text-white px-6 py-3 rounded-sm font-bold text-xs uppercase tracking-wider hover:bg-brand-secondary transition-colors cursor-pointer w-full justify-center shadow-md">
              Contáctenos <ArrowRight size={14} />
            </a>
          </div>

        </aside>
      </div>
    </div>
  </section>

</BaseLayout>
