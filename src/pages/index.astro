---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { ShieldCheck, BookOpen, Scale, ArrowRight, CheckCircle2, CalendarDays, Landmark, FileSignature, Briefcase } from 'lucide-react';

const ultimasPublicaciones = [
  {
    titulo: "Nuevas Reformas al Código de Comercio: Lo que su empresa debe saber",
    fecha: "20 Octubre, 2026",
    imagen: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&q=80&w=800",
  },
  {
    titulo: "Guía para la Resolución Alternativa de Conflictos en Contratos",
    fecha: "15 Octubre, 2026",
    imagen: "https://images.unsplash.com/photo-1521791055366-0d553872125f?auto=format&fit=crop&q=80&w=800",
  },
  {
    titulo: "Consecuencias Legales del Incumplimiento Laboral post-pandemia",
    fecha: "02 Octubre, 2026",
    imagen: "https://images.unsplash.com/photo-1507925921958-8a62f3d1a50d?auto=format&fit=crop&q=80&w=800",
  }
];
---

<BaseLayout 
  title="Inicio | Iuris&nbsp;Consultus" 
  description="Firma de Abogados y Notarios en Nicaragua. Asesoría legal experta, confiable y ética desde 1991.">
  
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- HERO SECTION — Parallax image, no video                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section
    class="hero-section relative overflow-hidden min-h-screen flex flex-col justify-center -mt-[74px]"
  >
    <!-- Parallax background image (fixed) -->
    <div
      class="absolute inset-0 w-full h-full z-0 hero-bg"
      style="background-image: url('https://images.unsplash.com/photo-1486325212027-8081e485255e?auto=format&fit=crop&q=85&w=2000'); background-size: cover; background-position: center top;"
    ></div>

    <!-- Gradient overlays for depth and text legibility -->
    <div class="absolute inset-0 z-10 hero-overlay-gradient"></div>
    <!-- Extra bottom fog so stats cards blend nicely -->
    <div class="absolute bottom-0 left-0 right-0 h-56 z-10" style="background: linear-gradient(to bottom, transparent, rgba(5,8,28,0.92));"></div>

    <!-- Content: left-aligned on large screens, centered on mobile -->
    <div class="container mx-auto px-6 relative z-20 text-white pt-40 pb-56 md:pb-64 lg:pb-72">
      <div class="max-w-3xl">

        <!-- Label eyebrow -->
        <p class="animate-reveal text-brand-accent font-bold tracking-[0.28em] uppercase text-xs mb-6 flex items-center gap-3">
          <span class="inline-block w-8 h-px bg-brand-accent"></span>
          Firma de Abogados &amp; Notarios · Desde 1991
        </p>

        <!-- Headline -->
        <h1 class="animate-reveal delay-75 font-serif font-bold leading-[1.08] tracking-tight drop-shadow-2xl text-white">
          <span class="block text-4xl md:text-5xl lg:text-6xl">Excelencia Legal</span>
          <span class="block text-3xl md:text-4xl lg:text-5xl text-brand-accent italic font-medium mt-3">
            En Centroamérica
          </span>
        </h1>

        <!-- Divider line with gold accent -->
        <div class="animate-reveal delay-150 flex items-center gap-4 my-7">
          <span class="w-12 h-px bg-brand-accent"></span>
          <span class="w-2 h-2 rounded-full bg-brand-accent opacity-60"></span>
        </div>

        <!-- Subtitle -->
        <p class="animate-reveal delay-200 text-base md:text-lg text-gray-300 max-w-xl leading-relaxed font-light">
          Desde 1991, brindamos resoluciones jurídicas inigualables en Nicaragua y la región, guiados por los más estrictos estándares éticos y corporativos.
        </p>

        <!-- CTA buttons -->
        <div class="animate-reveal delay-300 flex flex-col sm:flex-row gap-4 mt-10">
          <Button href="/contacto" variant="gold" size="lg" group>
            <span>Atención Inmediata</span>
            <ArrowRight size={16} className="group-hover:translate-x-1 transition-transform duration-300" />
          </Button>
          <Button href="/servicios" variant="ghost" size="lg" group>
            Nuestras Áreas
            <ArrowRight size={16} className="opacity-60 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300" />
          </Button>
        </div>

      </div>
    </div>
  </section>

  <!-- Wrapper para unir Hero + Stats + Sobre Nosotros de manera ininterrumpida -->
  <div class="bg-gradient-to-b from-[#05081C] via-[#191D32] to-[#F9F7F4]">
  
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- STATS CARDS                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <section class="relative z-30 -mt-24 md:-mt-32 pb-16 md:pb-24 px-6 pt-1">
      <div class="container mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          {[
            { value: "30", suffix: "+", label: "Años de Experiencia" },
            { value: "500", suffix: "+", label: "Casos Resueltos" },
            { value: "6", suffix: "", label: "Áreas de Práctica" },
            { value: "100", suffix: "%", label: "Compromiso Ético" },
          ].map((stat, i) => (
            <div class="scroll-reveal" style={`transition-delay: ${i * 80}ms`}>
              <div class="stat-card group bg-white/96 backdrop-blur-md p-6 md:p-7 rounded-sm shadow-xl border border-brand-slate/8 text-center flex flex-col justify-center items-center h-full relative overflow-hidden cursor-default">
                <div class="absolute top-0 left-0 w-full h-[3px] stat-card-bar"></div>
                <p class="text-4xl md:text-5xl font-black font-serif text-brand-primary mb-2 group-hover:text-brand-accent transition-colors duration-300 tabular-nums">
                  {stat.value}<span class="text-brand-accent group-hover:text-brand-primary transition-colors duration-300">{stat.suffix}</span>
                </p>
                <p class="text-brand-slate text-[10px] md:text-xs uppercase tracking-[0.22em] font-bold leading-tight">{stat.label}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- SOBRE NOSOTROS PREVIEW                                          -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <section class="pb-16 md:pb-24 relative">

      <div class="container mx-auto px-6 relative z-10">
        
        <!-- Tarjeta Contenedora Principal -->
        <div class="bg-white shadow-[0_20px_60px_rgba(0,0,0,0.15)] p-8 md:p-14 lg:p-20 relative">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center border-l-4 border-brand-accent pl-2 md:pl-0 lg:border-none lg:pl-0">
            
            <!-- Columna Texto (Izquierda) -->
            <div class="scroll-reveal-left order-2 lg:order-1 max-w-lg">
              <h2 class="text-3xl md:text-4xl font-bold font-serif text-[#745532] leading-snug mb-6">
                Excelencia Legal,<br/>Atención Personalizada
              </h2>
              
              <div class="text-[#4A4A4A] text-[15px] leading-relaxed space-y-5 mb-8">
                <p>
                  En Iuris Consultus comprendemos que cada situación jurídica es única. Nuestro compromiso trasciende la simple representación; somos aliados estratégicos en la defensa de sus derechos e intereses comerciales.
                </p>
                <p>
                  Ya sea que representemos a una corporación internacional o a particulares, nuestro propósito sigue intacto: proporcionar seguridad jurídica y resultados sostenibles.
                </p>
              </div>
              
              <!-- Firma al estilo de la referencia -->
              <div class="mt-10">
                 <span class="font-serif text-4xl italic text-[#2c3e50] opacity-90 tracking-tighter" style="font-family: 'Times New Roman', serif;">Iuris Consultus</span>
              </div>
            </div>

            <!-- Columna Imagen (Derecha) -->
            <div class="scroll-reveal-right order-1 lg:order-2 flex lg:justify-end">
              <div class="relative w-full max-w-md">
                
                <!-- Líneas Decorativas / Diseño de "Esquinas" -->
                <div class="absolute -top-3 -right-3 w-16 h-16 border-t-[3px] border-r-[3px] border-[#745532] z-20 transition-transform duration-500 hover:translate-x-2 hover:-translate-y-2 pointer-events-none"></div>
                <div class="absolute -bottom-3 -left-3 w-16 h-16 border-b-[3px] border-l-[3px] border-[#745532] z-20 transition-transform duration-500 hover:-translate-x-2 hover:translate-y-2 pointer-events-none"></div>
                
                <!-- Marco decorativo offset sutil tipo sombra/fondo -->
                <div class="absolute top-4 right-4 lg:-right-4 w-full h-full border border-brand-slate/20 rounded-sm z-0 pointer-events-none"></div>

                <img
                  src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=900"
                  alt="Oficinas de Iuris Consultus"
                  loading="lazy"
                  class="relative z-10 w-full aspect-[4/3] object-cover rounded-sm shadow-md transition-shadow duration-500 hover:shadow-xl"
                  width="500" height="375"
                />
              </div>
            </div>

          </div>
        </div>
        
      </div>
    </section>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- POR QUÉ IURIS CONSULTUS                                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- Continuación del degradado: Del crema hacia el blanco puro -->
  <section class="py-20 md:py-28 bg-gradient-to-b from-[#F9F7F4] via-brand-light to-white">
    <div class="container mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16 scroll-reveal">
        <p class="text-brand-accent font-bold tracking-[0.28em] uppercase text-xs mb-4 flex items-center justify-center gap-3">
          <span class="inline-block w-6 h-px bg-brand-accent"></span>
          La Firma
          <span class="inline-block w-6 h-px bg-brand-accent"></span>
        </p>
        <h2 class="text-3xl md:text-5xl font-bold font-serif text-brand-primary mb-4">¿Por qué Iuris Consultus?</h2>
        <div class="section-divider mt-4 mb-6"></div>
        <p class="text-brand-muted text-base leading-relaxed">
          Nuestro enfoque combina vasta experiencia con un análisis profundo de la ley para defender sus intereses y proteger su patrimonio con eficacia, transparencia y trato personalizado.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            icon: ShieldCheck,
            title: "Confianza y Ética",
            text: "Actuamos bajo los más altos estándares de integridad, asegurándole total transparencia y respeto en cada etapa del proceso legal.",
            delay: 0
          },
          {
            icon: Scale,
            title: "Experiencia Legal",
            text: "Más de tres décadas de trayectoria comprobada en la resolución de casos complejos en múltiples ramas del derecho.",
            delay: 100
          },
          {
            icon: BookOpen,
            title: "Atención Integral",
            text: "Abarcamos múltiples ramas del derecho para ofrecerle a usted o a su empresa una protección global, preventiva y estratégica.",
            delay: 200
          },
        ].map(({ icon: Icon, title, text, delay }) => (
          <div class="scroll-reveal" style={`transition-delay: ${delay}ms`}>
            <div class="feature-card group bg-white p-9 rounded-sm border-b-2 border-brand-accent/40 shadow-md hover:shadow-2xl transition-all duration-300 cursor-default h-full relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-0.5 feature-card-bar transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
              <div class="w-12 h-12 bg-brand-primary/8 rounded-sm flex items-center justify-center mb-6 text-brand-accent group-hover:bg-brand-accent group-hover:text-white transition-all duration-300">
                <Icon size={26} strokeWidth={1.5} />
              </div>
              <h3 class="text-lg font-bold font-serif mb-3 text-brand-dark">{title}</h3>
              <p class="text-brand-muted leading-relaxed text-sm">{text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- ÁREAS DE PRÁCTICA PREVIEW                                       -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-brand-warm">
    <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="scroll-reveal-left">
        <p class="text-brand-accent font-bold tracking-[0.28em] uppercase text-xs mb-4 flex items-center gap-3">
          <span class="inline-block w-6 h-px bg-brand-accent"></span>
          Especialidades
        </p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-serif mb-5 text-brand-primary leading-tight">Soluciones Legales<br/>a Su Medida</h2>
        <div class="section-divider ml-0 mt-0 mb-7"></div>
        <p class="text-brand-muted mb-8 text-base leading-relaxed">
          Comprendemos que cada situación es única. Nos dedicamos a encontrar la estrategia más favorable y expedita dentro del marco legal, protegiéndolo de posibles contingencias.
        </p>
        
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-6 mb-10">
          {[
            { icon: Landmark, label: "Derecho Bancario y Financiero" },
            { icon: FileSignature, label: "Asuntos Notariales e Inmobiliarios" },
            { icon: Scale, label: "Litigios Civiles y Resolución de Conflictos" },
            { icon: Briefcase, label: "Derecho Laboral y Administrativo" },
          ].map(({ icon: Icon, label }) => (
            <li class="flex items-center gap-3 group w-full cursor-default">
              <div class="w-8 h-8 rounded-sm bg-brand-accent/10 flex items-center justify-center shrink-0 group-hover:bg-brand-accent transition-colors duration-300">
                <Icon className="text-brand-accent group-hover:text-white transition-colors duration-300" size={15} />
              </div>
              <span class="text-brand-dark text-sm font-medium">{label}</span>
            </li>
          ))}
        </ul>
        
        <Button href="/servicios" variant="gold" group>
          Ver Todas Las Áreas
          <ArrowRight size={15} className="group-hover:translate-x-1 transition-transform duration-300" />
        </Button>
      </div>
      
      <div class="relative scroll-reveal-right">
        <div class="absolute -top-4 -left-4 w-full h-full border border-brand-accent/25 rounded-sm z-0 pointer-events-none"></div>
        <div class="absolute -bottom-4 -right-4 w-20 h-20 bg-brand-accent/8 rounded-sm z-0 pointer-events-none"></div>
        <img
          src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80&w=1200"
          alt="Documentos y servicios legales profesionales"
          loading="lazy"
          class="relative z-10 w-full rounded-sm shadow-xl hover:shadow-2xl transition-shadow duration-500"
          width="600" height="400"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- TESTIMONIOS                                                      -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="py-16 md:py-20 testimonials-bg relative overflow-hidden">
    <div class="absolute inset-0 testimonials-overlay z-0 pointer-events-none"></div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16 scroll-reveal">
        <p class="text-brand-accent font-bold tracking-[0.28em] uppercase text-xs mb-4 flex items-center justify-center gap-3">
          <span class="inline-block w-6 h-px bg-brand-accent"></span>
          Testimonios
          <span class="inline-block w-6 h-px bg-brand-accent"></span>
        </p>
        <h2 class="text-3xl md:text-5xl font-bold font-serif text-brand-primary mb-4">La Confianza de Nuestros Clientes</h2>
        <div class="section-divider mt-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            quote: "El equipo de Iuris Consultus nos brindó una asesoría impecable durante la reestructuración de nuestra empresa. Su profesionalismo y conocimiento del marco legal nicaragüense es excepcional.",
            role: "Director General, Grupo Financiero",
            initials: "JR",
            delay: 0
          },
          {
            quote: "Confiamos plenamente en su capacidad para manejar nuestros asuntos notariales e inmobiliarios. Han sido aliados estratégicos para nuestro crecimiento en la región centroamericana.",
            role: "Gerente de Operaciones, Constructora Nacional",
            initials: "ML",
            delay: 100
          },
          {
            quote: "La resolución de nuestro caso laboral fue rápida y favorable gracias a la intervención oportuna y experta de Iuris Consultus. Recomendados completamente.",
            role: "Propietario, Importadora del Pacífico",
            initials: "CP",
            delay: 200
          }
        ].map(({ quote, role, initials, delay }) => (
          <div class="scroll-reveal" style={`transition-delay: ${delay}ms`}>
            <div class="testimonial-card group bg-white rounded-sm p-6 shadow-sm hover:shadow-xl transition-all duration-400 relative flex flex-col h-full border border-brand-slate/8 hover:border-brand-accent/20">
              <div class="absolute -top-3 -right-3 w-14 h-14 bg-brand-accent/10 rounded-full blur-xl pointer-events-none"></div>
              <p class="text-brand-muted text-[14px] leading-relaxed mb-5 italic grow">
                <span class="text-brand-accent font-serif text-2xl leading-none mr-1.5 opacity-60">"</span>{quote}
              </p>
              <!-- Initials avatar + role only (no name) -->
              <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
                <div class="w-10 h-10 bg-brand-primary rounded-full flex items-center justify-center text-brand-accent font-bold text-xs shrink-0">
                  {initials}
                </div>
                <p class="text-brand-slate text-xs leading-tight">{role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- ÚLTIMAS PUBLICACIONES                                            -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-gradient-to-b from-white to-brand-warm">
    <div class="container mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16 scroll-reveal">
        <p class="text-brand-accent font-bold tracking-[0.28em] uppercase text-xs mb-4 flex items-center justify-center gap-3">
          <span class="inline-block w-6 h-px bg-brand-accent"></span>
          Blog Jurídico
          <span class="inline-block w-6 h-px bg-brand-accent"></span>
        </p>
        <h2 class="text-3xl md:text-5xl font-bold font-serif text-brand-primary mb-4">Últimas Publicaciones</h2>
        <div class="section-divider mt-4 mb-6"></div>
        <p class="text-brand-muted text-base leading-relaxed">
          Manténgase informado con los análisis legales más recientes de nuestros profesionales.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-7 mb-12">
        {ultimasPublicaciones.map((articulo, index) => (
          <div class="scroll-reveal" style={`transition-delay: ${index * 100}ms`}>
            <article class="blog-card group bg-white rounded-sm shadow-sm hover:shadow-xl transition-all duration-400 cursor-pointer flex flex-col h-full border border-transparent hover:border-brand-accent/15 overflow-hidden">
              <!-- Image only — no badges, no category -->
              <a href="/blog" class="block h-52 overflow-hidden relative">
                <img
                  src={articulo.imagen}
                  alt={articulo.titulo}
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width="400" height="208"
                />
                <div class="absolute inset-0 bg-brand-dark/0 group-hover:bg-brand-dark/15 transition-all duration-400"></div>
              </a>

              <div class="p-6 flex flex-col grow">
                <!-- Date only -->
                <time class="text-[11px] text-brand-slate font-medium flex items-center gap-1.5 mb-3">
                  <CalendarDays size={11} className="text-brand-accent" />
                  {articulo.fecha}
                </time>

                <!-- Title -->
                <h3 class="text-base font-bold font-serif text-brand-dark leading-snug group-hover:text-brand-accent transition-colors duration-300">
                  <a href="/blog">{articulo.titulo}</a>
                </h3>
              </div>
            </article>
          </div>
        ))}
      </div>

      <div class="text-center scroll-reveal">
        <Button href="/blog" variant="outline" group>
          Ver Más Publicaciones
          <ArrowRight size={15} className="group-hover:translate-x-1 transition-transform duration-300" />
        </Button>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Hero background ── */
.hero-bg {
  background-attachment: scroll; /* scroll en móvil/iOS — siempre funciona */
}
@media (min-width: 1024px) and (hover: hover) {
  /* Parallax solo en desktop con mouse — nunca en touch/iOS */
  .hero-bg {
    background-attachment: fixed;
  }
}

/* ── Hero overlay ── */
.hero-overlay-gradient {
  background: linear-gradient(
    135deg,
    rgba(5, 8, 28, 0.82) 0%,
    rgba(5, 8, 28, 0.65) 40%,
    rgba(5, 8, 28, 0.50) 100%
  );
}

/* ── Stat cards top bar ── */
.stat-card-bar {
  background: linear-gradient(90deg, var(--color-brand-accent), var(--color-brand-accent-light));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.45s ease;
}
.stat-card:hover .stat-card-bar {
  transform: scaleX(1);
}

/* ── Feature cards top bar ── */
.feature-card-bar {
  background: linear-gradient(90deg, var(--color-brand-accent), var(--color-brand-accent-light));
}

/* ── Testimonials ── */
.testimonials-bg { background-color: #fff; }
.testimonials-overlay {
  background: radial-gradient(ellipse 70% 60% at 50% 100%, rgba(184,148,62,0.04) 0%, transparent 70%);
}
</style>